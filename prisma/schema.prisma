generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// 食品流通システム - User Authentication
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // Hashed password (bcrypt)
  avatarUrl String?
  role      String   @default("USER") // ADMIN, USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  diaries   Diary[]    @relation("UserDiaries")
  goals     Goal[]     @relation("UserGoals")
  entries   Entry[]    @relation("UserEntries")
  sharedBy  SharedEntry[]
  likedBy   EntryLike[]

  @@map("users")
}

// ============================================
// 食品流通システム - Core Features
// ============================================

// 日記（Diary - legacy, kept for compatibility）
model Diary {
  id        String   @id @default(cuid())
  title     String
  content   String
  date      DateTime @default(now())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserDiaries", fields: [userId], references: [id], onDelete: Cascade)

  @@map("diaries")
}

// 目標（Goal - WakuWaku List / Target Management）
model Goal {
  id        String   @id @default(cuid())
  title     String
  content   String?  // Optional description
  target    DateTime? // Optional target date
  completed Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserGoals", fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

// エントリ（Entry - 24h Weekly View）
model Entry {
  id          String          @id @default(cuid())
  userId      String
  year        Int
  week        Int
  dayOfWeek   Int             // 0=Sunday, 1=Monday, ..., 6=Saturday
  hour        Int             // 0-23
  content     String?
  isCompleted Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user      User            @relation("UserEntries", fields: [userId], references: [id])
  images    EntryImage[]
  likes     EntryLike[]
  shared    SharedEntry?

  @@unique([userId, year, week, dayOfWeek, hour])
  @@map("entries")
}

// エントリ画像（Entry Image - Handwriting images）
model EntryImage {
  id        String   @id @default(cuid())
  entryId   String
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("entry_images")
}

// ============================================
// 食品流通システム - Sharing & Likes
// ============================================

// 共有エントリ（Shared Entry - Secure token-based sharing）
model SharedEntry {
  id           String   @id @default(cuid())
  entryId      String   @unique
  sharedById   String
  shareToken   String   @unique
  viewCount    Int      @default(0)
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  sharedBy User    @relation(fields: [sharedById], references: [id])
  entry    Entry   @relation(fields: [entryId], references: [id])

  @@map("shared_entries")
}

// エントリアイク（Entry Like - Like system）
model EntryLike {
  id        String   @id @default(cuid())
  entryId   String
  userId    String?
  ipAddress String?  // For anonymous likes
  createdAt DateTime @default(now())

  entry Entry? @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId, ipAddress])
  @@map("entry_likes")
}
